<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Posts</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h1>QUORA POSTS</h1>
    <br>
    <a href="http://localhost:8080/posts/new">Create New Post</a>
    <% for(user of users) {%>
        <div class="post">
            <h2 class="user">@<%= user.username %></h2>
            <h4 class="content"><%= user.content %></h4>
            <a href="http://localhost:8080/posts/<%=user.id%>">see in detail</a>&nbsp;&nbsp;
            <a href="http://localhost:8080/posts/<%=user.id%>/edit">Edit</a>
            <form method="post" action="/posts/<%=user.id%>?_method=DELETE">
                <button>Delete</button>
            </form>
        </div>
        <%}%>
</body>
</html>