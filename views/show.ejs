<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post In Details</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h2>Here is Your Post in Details</h2>
    
    <div class="post">
        <h2 class="user">@<%= user.username %></h2>
        <h4 class="content"><%= user.content %></h4>
    </div>
    <br>
    <a href="http://localhost:8080/posts">Go Back</a>
</body>
</html>